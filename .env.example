# DLX Solution Website Configuration
# Copy this file to .env and update as needed

FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here
PORT=5000

# Contact form email configuration (Brevo API)
# Sign up at https://www.brevo.com, create an API key,
# and verify your sender email (e.g. support.dlx@dlxsolution.com).
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM_EMAIL=support.dlx@dlxsolution.com
BREVO_FROM_NAME=DLX Solution

# Destination address for contact form submissions
CONTACT_TO=support.dlx@dlxsolution.com
