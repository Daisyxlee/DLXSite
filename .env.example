# DLX Solution Website Configuration
# Copy this file to .env and update as needed

FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here
PORT=5000

# Outgoing email configuration for contact form
# Option 1: SendGrid (recommended on Render)
# Get an API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your-sendgrid-api-key

# Verified sender / from address for SendGrid
MAIL_FROM=support.dlx@dlxsolution.com

# Destination address for contact form submissions (Zoho inbox)
CONTACT_TO=support.dlx@dlxsolution.com

# Option 2: Direct SMTP (only if your host allows outbound SMTP)
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=587
# SMTP_USER=support.dlx@dlxsolution.com
# SMTP_PASSWORD=your-zoho-app-password
# SMTP_USE_TLS=1
