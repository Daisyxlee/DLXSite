# DLX Solution Website Configuration
# Copy this file to .env and update as needed

FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here
PORT=5000

# Outgoing email configuration for contact form
# Update these values with your SMTP provider details.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=1

# Destination address for contact form submissions
CONTACT_TO=support.dlx@dlxsolution.com
